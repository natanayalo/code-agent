    {
      "case_id": "case-pitfall-wrapper-correction",
      "task_text": "Fix command run",
      "repo_url": "github.com/owner/repo",
      "observations": [
        {
          "source": "worker",
          "event_type": "worker_completed",
          "summary": "Completed successfully.",
          "content": "Resolved.",
          "metadata_payload": {
            "commands_run": [
              {"command": "python script.py", "exit_code": 1},
              {"command": "poetry run python script.py", "exit_code": 0}
            ]
          }
        }
      ],
      "expected_candidates": [
        {
          "memory_key": "known_pitfalls",
          "category": "project",
          "value": {
            "note": "Command 'python script.py' failed; use 'poetry run python script.py' instead.",
            "failed_command": "python script.py",
            "corrected_command": "poetry run python script.py"
          }
        }
      ],
      "expected_admission_decisions": ["needs_human_review"],
      "expected_proposals": ["known_pitfalls"]
    },
    {
      "case_id": "case-pitfall-target-match",
      "task_text": "Fix target path command",
      "repo_url": "github.com/owner/repo",
      "observations": [
        {
          "source": "worker",
          "event_type": "worker_completed",
          "summary": "Completed.",
          "content": "Resolved path.",
          "metadata_payload": {
            "commands_run": [
              {"command": "pytest tests/foo", "exit_code": 1},
              {"command": ".venv/bin/pytest tests/foo", "exit_code": 0}
