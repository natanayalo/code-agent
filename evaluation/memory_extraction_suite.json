      "expected_candidates": [
        {
          "memory_key": "known_pitfalls",
          "category": "project",
          "value": {
            "note": "Command 'pytest tests/foo' failed; use '.venv/bin/pytest tests/foo' instead.",
            "failed_command": "pytest tests/foo",
            "corrected_command": ".venv/bin/pytest tests/foo"
          }
        },
        {
          "memory_key": "verification_commands",
          "category": "project",
          "value": {
            ".venv/bin/pytest tests/foo": ".venv/bin/pytest tests/foo"
          }
        }
      ],
      "expected_admission_decisions": ["create", "needs_human_review"],
      "expected_proposals": ["known_pitfalls"],
      "expected_durable_memory_keys": ["verification_commands"]
