{
  "suite_name": "Deterministic Memory Extraction Suite",
  "cases": [
    {
      "case_id": "case-verification-clean-success",
      "task_text": "Run pytest tests/unit",
      "repo_url": "github.com/owner/repo",
      "observations": [
        {
          "source": "worker",
          "event_type": "worker_completed",
          "summary": "Completed successfully.",
          "content": "Passed all unit tests.",
          "metadata_payload": {
            "commands_run": [
              {"command": "pytest tests/unit", "exit_code": 0}
            ]
          }
        }
      ],
      "expected_candidates": [
        {
          "memory_key": "verification_commands",
          "category": "project",
          "value": {
            "pytest tests/unit": "pytest tests/unit"
          }
        }
      ],
      "expected_admission_decisions": ["create"],
      "expected_durable_memory_keys": ["verification_commands"]
    },
