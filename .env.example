POSTGRES_DB=code_agent
POSTGRES_USER=code_agent
# Replace with a strong local-only password before running Docker Compose.
POSTGRES_PASSWORD=changeme
DATABASE_HOST=postgres
DATABASE_PORT=5432
CODE_AGENT_API_SHARED_SECRET=change-me
CODE_AGENT_ENABLE_TASK_SERVICE=1
CODE_AGENT_RUN_API=1
CODE_AGENT_RUN_WORKER=0
# Telegram bot token for sending progress replies back to chats.
# CODE_AGENT_TELEGRAM_BOT_TOKEN=<your-bot-token-from-BotFather>
# Optional: secret Telegram includes in X-Telegram-Bot-Api-Secret-Token header.
# CODE_AGENT_TELEGRAM_WEBHOOK_SECRET_TOKEN=change-me
# Optional: Comma-separated list of trusted origins for dashboard CSRF protection.
# Required for dashboard mutating actions (e.g., approval, replay).
# CODE_AGENT_ALLOWED_ORIGINS=http://localhost:3000
# Optional: Set to 1 to force Secure cookies (required behind HTTPS proxies).
# CODE_AGENT_COOKIE_SECURE=0

# CLI Worker Configuration
# CODE_AGENT_CODEX_CLI_BIN=codex
# CODE_AGENT_CODEX_MODEL=gpt-5.4
# CODE_AGENT_CODEX_PROFILE=default
# CODE_AGENT_CODEX_TIMEOUT_SECONDS=120
# Native-agent defaults are pinned; tool_loop values are deprecated and ignored for defaults.
# CODE_AGENT_CODEX_RUNTIME_MODE=native_agent
# Production-like default should allow workspace writes.
# CODE_AGENT_CODEX_SANDBOX=workspace-write
# Optional escape hatch to keep CODE_AGENT_CODEX_SANDBOX=read-only in up.sh.
# CODE_AGENT_ALLOW_READ_ONLY_SANDBOX=1
# CODE_AGENT_GEMINI_CLI_BIN=gemini
# CODE_AGENT_GEMINI_MODEL=gemini-2.5-pro
# CODE_AGENT_GEMINI_TIMEOUT_SECONDS=120
# Native-agent defaults are pinned; tool_loop values are deprecated and ignored for defaults.
# CODE_AGENT_GEMINI_RUNTIME_MODE=native_agent
# Optional: explicit legacy tool-loop profile opt-in for Codex/Gemini.
# Use together with per-task worker_profile_override (for example codex-tool-loop-executor).
# CODE_AGENT_CODEX_TOOL_LOOP_LEGACY_ENABLED=1
# CODE_AGENT_GEMINI_TOOL_LOOP_LEGACY_ENABLED=1
# Optional sandbox container image used for task execution (must include git).
# CODE_AGENT_SANDBOX_IMAGE=code-agent-worker
# Host auth dirs mounted into worker container (CLI login-based auth)
# CODE_AGENT_CODEX_AUTH_DIR=/Users/<you>/.codex
# CODE_AGENT_GEMINI_AUTH_DIR=/Users/<you>/.gemini

# Queue / worker settings
# CODE_AGENT_QUEUE_POLL_INTERVAL_SECONDS=2
# CODE_AGENT_QUEUE_LEASE_SECONDS=60
# CODE_AGENT_QUEUE_MAX_ATTEMPTS=3
# Optional: local SQLite files outside the repository root to avoid accidental commits.
# DATABASE_URL=sqlite:///$HOME/.code-agent/data/code-agent.db
# CODE_AGENT_CHECKPOINT_DB_PATH=$HOME/.code-agent/data/checkpoints.db
# Host-shared workspace root used by worker sandbox bind-mounts
# CODE_AGENT_WORKSPACE_ROOT=/Users/<you>/.code-agent/workspaces

# Optional: enable OTEL/OpenInference tracing to local/self-hosted Phoenix.
# scripts/up.sh will auto-start Phoenix when CODE_AGENT_ENABLE_TRACING=1.
# Start Phoenix manually with: docker compose --profile observability up -d phoenix
# CODE_AGENT_ENABLE_TRACING=1
# CODE_AGENT_TRACING_PROJECT=code-agent-local
# CODE_AGENT_TRACING_OTLP_ENDPOINT=http://phoenix:6006/v1/traces

# ngrok tunnel (for public HTTPS access — required for Telegram webhook).
# Get your authtoken free at: dashboard.ngrok.com → Your Authtoken
# NGROK_AUTHTOKEN=<your-authtoken>
# Optional: stable static domain (free at: dashboard.ngrok.com → Domains → New Domain).
# Without this, the URL changes on every restart and you must re-register the webhook.
# NGROK_DOMAIN=your-name.ngrok-free.app

# Optional: Default repository to use for tasks submitted via Telegram.
# CODE_AGENT_TELEGRAM_DEFAULT_REPO_URL=https://github.com/your-user/your-repo
# Optional: Default repository to use for tasks submitted via /webhook when repo_url is omitted.
# CODE_AGENT_WEBHOOK_DEFAULT_REPO_URL=https://github.com/your-user/your-repo
